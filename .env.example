# YouTube auth (cookies — run: python scripts/extract_cookies.py)
YOUTUBE_COOKIES_FILE=./cookies.txt  # Netscape format, extracted from Firefox

# Directories
WORKING_DIR=./workdir
OUTPUT_DIR=./output

# Pipeline settings
MAX_CLIPS=5            # nombre max de clips par vidéo
CLIP_MIN_DURATION=60   # durée min d'un clip (secondes)
CLIP_MAX_DURATION=90   # durée max d'un clip (secondes)

# Workers
NUM_WORKERS=4          # workers pour le scoring/extraction audio (2 pour Railway, 4+ pour PC costaud)
RENDER_WORKERS=1       # clips rendus en parallèle (1 = économise la RAM, 2+ si 16 Go+ de RAM)

# Whisper (transcription / sous-titres)
WHISPER_MODEL=small    # tiny (rapide) / base (compromis) / small (meilleur) / medium (lent mais précis)
