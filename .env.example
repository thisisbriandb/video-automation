# YouTube auth (cookies — run: python scripts/extract_cookies.py)
YOUTUBE_COOKIES_FILE=./cookies.txt  # Netscape format, extracted from Firefox

# Directories
WORKING_DIR=./workdir
OUTPUT_DIR=./output

# Pipeline settings
MAX_CLIPS=5
CLIP_MIN_DURATION=15
CLIP_MAX_DURATION=60
NUM_WORKERS=2          # parallel workers (2 for Railway, higher for beefy machines)
WHISPER_MODEL=small    # tiny/base/small/medium (small = best quality/speed tradeoff)
